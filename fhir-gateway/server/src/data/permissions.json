  "accessPolicies": [
    {
      "role": "role_admin",
      "resources": ["Patient", "Encounter", "MedicationRequest", "DiagnosticReport", "Observation"],
      "departments": ["*"],
      "fields": ["*"],
      "actions": ["read", "write", "manage"]
    },
    {
      "role": "role_doctor",
      "resources": ["Patient", "Encounter", "MedicationRequest", "DiagnosticReport", "Observation"],
      "departments": ["$own"],
      "fields": ["*"],
      "actions": ["read"]
    },
    {
      "role": "role_nurse",
      "resources": ["Patient", "Encounter", "MedicationRequest"],
      "departments": ["$own"],
      "fields": ["identifier", "name", "gender", "birthDate", "class", "period", "medication", "dosage"],
      "actions": ["read"]
    },
    {
      "role": "role_lab_tech",
      "resources": ["Patient", "DiagnosticReport", "Observation"],
      "departments": ["*"],
      "fields": ["identifier", "name", "code", "value", "unit", "referenceRange", "status"],
      "actions": ["read"]
    }
  ]
}
