# ===== MySQL 源库 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=cdc_user
MYSQL_PASSWORD=cdc_pass
MYSQL_DATABASE=hospital_his
MYSQL_SERVER_ID=1001

# ===== SQL Server 源库 =====
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrong!Pass123
